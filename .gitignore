# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.local

# tsc 输出（防止误跑 tsc 在模板源码上生成产物，污染镜像 / 触发 vite ESM 加载错误）
*.tsbuildinfo
src/**/*.js
src/**/*.d.ts
functions/**/*.js
functions/**/*.d.ts
vite.config.js
vite.config.d.ts
vitest.config.js
vitest.config.d.ts
# Vite 环境声明（合法的，必须保留）
!src/vite-env.d.ts

